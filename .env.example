# Copy to .env and fill in values. Never commit .env.

SUPABASE_URL=https://your-project-ref.supabase.co
# Use service_role key on the server for inserts (keep secret), or anon if RLS allows insert.
SUPABASE_KEY=your_supabase_secret_key

PORT=3000
# Optional: max JSON body size for large base64 watermarked images (default 50mb)
# BODY_JSON_LIMIT=50mb
